{
  "lexicon": 1,
  "id": "app.musicsky.temp.getFeed",
  "defs": {
    "main": {
      "type": "query",
      "description": "Get a chronological feed of songs.",
      "parameters": {
        "type": "params",
        "properties": {
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 50,
            "description": "Maximum number of results."
          },
          "cursor": {
            "type": "string",
            "description": "Pagination cursor."
          },
          "viewer": {
            "type": "string",
            "description": "DID of the viewing user for viewer state."
          }
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["songs"],
          "properties": {
            "cursor": {
              "type": "string"
            },
            "songs": {
              "type": "array",
              "items": {
                "type": "ref",
                "ref": "#songView"
              }
            }
          }
        }
      }
    },
    "songView": {
      "type": "object",
      "required": ["uri", "cid", "author", "record", "indexedAt"],
      "properties": {
        "uri": { "type": "string" },
        "cid": { "type": "string" },
        "author": {
          "type": "ref",
          "ref": "#authorView"
        },
        "record": { "type": "unknown" },
        "likeCount": { "type": "integer" },
        "repostCount": { "type": "integer" },
        "viewer": {
          "type": "ref",
          "ref": "#viewerState"
        },
        "indexedAt": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    },
    "authorView": {
      "type": "object",
      "required": ["did", "handle", "pds"],
      "properties": {
        "did": { "type": "string" },
        "handle": { "type": "string" },
        "pds": { "type": "string" }
      }
    },
    "viewerState": {
      "type": "object",
      "properties": {
        "like": { "type": "string" },
        "repost": { "type": "string" }
      }
    }
  }
}
