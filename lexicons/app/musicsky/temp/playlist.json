{
  "lexicon": 1,
  "id": "app.musicsky.temp.playlist",
  "defs": {
    "main": {
      "type": "record",
      "description": "Record representing a user-curated playlist of tracks.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": ["name", "tracks", "createdAt"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 512,
            "maxGraphemes": 100,
            "description": "Name of the playlist."
          },
          "description": {
            "type": "string",
            "maxLength": 5000,
            "maxGraphemes": 1000,
            "description": "Optional description of the playlist."
          },
          "tracks": {
            "type": "array",
            "items": {
              "type": "ref",
              "ref": "com.atproto.repo.strongRef"
            },
            "maxLength": 500,
            "description": "Ordered list of strong references to tracks. Max 500 tracks per playlist."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Client-declared timestamp of when the playlist was created."
          }
        }
      }
    }
  }
}
