{
  "lexicon": 1,
  "id": "app.musicsky.temp.repost",
  "defs": {
    "main": {
      "type": "record",
      "description": "Record representing an account reposting a track.",
      "key": "tid",
      "record": {
        "type": "object",
        "required": [
          "subject",
          "createdAt"
        ],
        "properties": {
          "subject": {
            "type": "ref",
            "ref": "com.atproto.repo.strongRef",
            "description": "Strong reference to the track being reposted."
          },
          "createdAt": {
            "type": "string",
            "format": "datetime",
            "description": "Client-declared timestamp of when the repost was created."
          }
        }
      }
    }
  }
}