{
  "name": "appview",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "pnpm run migrate && node dist/index.js",
    "migrate": "tsx src/scripts/migrate.ts",
    "typecheck": "tsc",
    "lint": "eslint",
    "knip": "knip",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@atproto/syntax": "^0.3.2",
    "@atproto/tap": "^0.1.0",
    "better-sqlite3": "^12.6.2",
    "common": "workspace:*",
    "express": "^5.0.1",
    "kysely": "^0.28.11"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.1",
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "knip": "^5.86.0",
    "tsup": "^8",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.0"
  }
}
